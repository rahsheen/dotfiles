#!/usr/bin/env ruby

# ai-dev: The Senior Engineer's Aider Dispatcher
# Usage: ai-dev <command> [args]

command = ARGV[0]
target = ARGV[1]

SKILLS_DIR = File.expand_path("~/.agents/skills")
PLAN_FILE = "plan.md"

def run_aider(args)
  system("aider --chat-history-file /dev/null --no-restore-chat-history #{args}")
end

case command
when "architect"
  # 1. Fetch from Jira CLI (Vetted Ticket)
  puts "🔍 Fetching ticket #{target}..."
  ticket_body = `jira issue view #{target} --plain`

  # 2. Initialize the Plan (The 'Journey' scratchpad)
  File.write(PLAN_FILE, "# Plan: #{target}\n\n## Jira Context\n#{ticket_body}\n\n---\n## TODO Checklist\n- [ ] ")

  puts "🏗️  Launching Architect Mode..."
  # Load the Modified Grill Skill and focus on side-effects/design tree
  run_aider("--read #{SKILLS_DIR}/groom-ticket/SKILL.md #{PLAN_FILE} --chat-mode ask")

when "implement"
  # 3. TDD Implementation Loop
  puts "🧪 Launching TDD Implementation Mode..."
  # Ensure Aider knows the plan and the TDD skill
  run_aider("--read #{SKILLS_DIR}/tdd/SKILL.md #{PLAN_FILE}")

when "review"
  puts "🧐 Auditing local changes..."
  diff = `git diff origin/staging...HEAD`
  File.write(".aider.diff.tmp", diff)

  REVIEW_PROMPT = "Use our rails-reviewer skill to provide feedback on the included diff. " \
                  "Check for regressions or missed test cases. " \
                  "Write your full analysis into 'rails-review.md'. " \
                  "Do not output the review to the chat, just write the rails-review.md file."

  run_aider(
    "--chat-mode ask " \
    "--read #{SKILLS_DIR}/rails-reviewer.md " \
    "--read .aider.diff.tmp " \
    "--file rails-review.md " \
    "--message \"#{REVIEW_PROMPT}\""
  )

  File.delete(".aider.diff.tmp")
else
  puts "Usage: ai-dev [architect <JIRA-ID> | implement | review]"
end
